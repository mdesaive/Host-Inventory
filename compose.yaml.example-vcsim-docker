services:

  node_exporter:
    image: prom/node-exporter:latest
    restart: unless-stopped
    command:
      - "--collector.textfile.directory=/textfiles"
    volumes:
      - ./textfiles:/textfiles:ro
    ports:
      - "9101:9100" # Select distinct port for node exporter.

  sidecar_tools01:
    image: python:3.12-slim
    restart: unless-stopped
    environment:
      HOST: "${DCK01_HOST}"
      SCRAPE_INTERVAL: "${SCRAPE_INTERVAL:-300}"
    volumes:
      - ./app:/app:ro
      - ./textfiles:/textfiles
    working_dir: /app
    command: >
      sh -c '
        pip install --quiet -r /app/requirements.txt &&
        while true; do
          python /app/main.py --source docker --output prometheus \
            --host "$$HOST" \
            > /textfiles/docker_tools01.prom \
            || echo "[sidecar_docker] Export failed, retrying in $$SCRAPE_INTERVAL s"
          sleep $$SCRAPE_INTERVAL
        done
      '
