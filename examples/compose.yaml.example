# docker-compose.yml
# ------------------
# VM Metadata Exporter - Production Setup
#
# Services:
#   node_exporter      - Prometheus node exporter with textfile collector
#   sidecar-vms-docker     - Collects Docker container metadata (every 5 min)
#   sidecar-vms-vmware     - Collects VMware VM metadata (every 15 min)
#   sidecar-networks-docker - Collects Docker network attachments (every 15 min)
#   sidecar-networks-vmware - Collects VMware network attachments (twice daily)
#
# Setup:
#   cp .env.example .env        # then edit .env
#   echo "secret" > secrets/vmware_password.txt
#   docker compose build
#   docker compose up -d
#
# Environment variables (.env):
#   DOCKER_HOST       - Docker daemon URL, e.g. http://192.168.1.10:2375
#   VMWARE_HOST       - vCenter URL, e.g. https://vcenter.example.com #   VMWARE_USERNAME   - vCenter username
#   NO_VERIFY_SSL     - Set to --no-verify-ssl for self-signed certs

secrets:
  vmware_password:
    file: ./secrets/vmware_password.txt

volumes:
  textfiles:

services:

  node_exporter:
    image: prom/node-exporter:latest
    restart: unless-stopped
    command:
      - "--collector.disable-defaults"
      - "--collector.textfile"
      - "--collector.textfile.directory=/textfiles"
    volumes:
      - textfiles:/textfiles:ro
    ports:
      - "9101:9100"

  sidecar-docker:
    build: .
    restart: unless-stopped
    env_file:
      env_files/env_docker
    volumes:
      - ./app:/app:ro
      - ./crontabs/crontab-docker:/crontab:ro
      - textfiles:/textfiles

  sidecar-vmware:
    build: .
    restart: unless-stopped
    env_file:
      env_files/env_vmware
    secrets:
      - vmware_password
    volumes:
      - ./app:/app:ro
      - ./crontabs/crontab-vmware:/crontab:ro
      - textfiles:/textfiles
