# compose.yaml
# ------------
# Host Inventory - Prometheus Textfile Collector setup
#
# Services:
#   node_exporter     - Prometheus node exporter, textfile collector only,
#                       exposes the .prom files written by the sidecars
#   sidecar-docker01  - Collects container metadata from one Docker host
#                       via supercronic (see crontabs/). Duplicate this
#                       block once per Docker host.
#   sidecar-vmware    - Collects VM metadata from vCenter via supercronic
#
# Setup: see README.md ("Docker Compose setup"). In short:
#   cp examples/env_docker.example env_files/env_docker01   # one per host
#   cp examples/env_vmware.example env_files/env_vmware
#   cp examples/crontab-docker.example crontabs/crontab-docker
#   cp examples/crontab-vmware.example crontabs/crontab-vmware
#   echo "your_vcenter_password" > secrets/vmware_password.txt
#   docker compose build && docker compose up -d
#
# Environment variables are documented in the README and the
# examples/env_*.example files (INV_HOST, INV_USERNAME,
# INV_PROM_FILE_CHEAP).

secrets:
  vmware_password:
    file: ./secrets/vmware_password.txt

volumes:
  textfiles:

services:
  node_exporter:
    image: prom/node-exporter:latest
    restart: unless-stopped
    command:
      - "--collector.disable-defaults"
      - "--collector.textfile"
      - "--collector.textfile.directory=/textfiles"
    volumes:
      - textfiles:/textfiles:ro
    ports:
      - "9101:9100"

  # One sidecar per Docker host. Duplicate this block and adjust the
  # service name and env_file (env_docker01, env_docker02, ...).
  sidecar-docker01:
    build: .
    restart: unless-stopped
    env_file:
      - env_files/env_docker01
    volumes:
      - ./app:/app:ro
      - ./crontabs/crontab-docker:/crontab:ro
      - textfiles:/textfiles

  sidecar-vmware:
    build: .
    restart: unless-stopped
    env_file:
      - env_files/env_vmware
    secrets:
      - vmware_password
    volumes:
      - ./app:/app:ro
      - ./crontabs/crontab-vmware:/crontab:ro
      - textfiles:/textfiles
